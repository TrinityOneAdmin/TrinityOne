# internal dev-box APK index (generated by scripts/build-apk-index.sh — not for public deploy)
apks.html
relay/relay-settings.json
.github/workflows/
relay/origin
relay/.update-request
relay/update.log
relay/.code-backup.tgz
# release signing secret — lives ONLY on the release host, never committed.
# (the matching PUBLIC key is baked in: relay-app/release-pubkey.pem + the
#  RELEASE_PUBKEY_PEM constant in scripts/gateway.mjs)
relay/release-key.pem
# per-HEAD cached self-update bundle + detached signature (generated on demand)
relay/.bundle-cache/
# catalog publisher secret — pulled from claude/blossom; the matching PUBKEY is
# baked into engine.js / scripts/gateway.mjs as CATALOG_PUB. Loss = forced ecosystem
# rotation (members trust the next-shipped pubkey instead). Anchor on main pre-emptively
# so that if/when Blossom merges, the gitignore is already in place.
relay/catalog-key.json

# internal-only (not for the public repo)
SECURITY-AUDIT-*.md
*-handoff*.zip
reference/archive/
HANDOFF.md

# local/agent cruft — never publish
.claude/
*.tmp.*
*.bak-*
relay/*.demo-backup*
reference/TrinityOne.zip
reference/nas-relay/
payments-options.html
