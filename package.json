{
  "name": "trinityone",
  "version": "0.1.0",
  "description": "Offline-first Bible app with anonymous Nostr fellowship + Lightning giving",
  "main": "engine.js",
  "scripts": {
    "relay": "node relay/dev-relay.mjs",
    "serve": "python3 -m http.server 8000",
    "dev": "node relay/dev-relay.mjs & python3 -m http.server 8000",
    "build:vendor": "bash scripts/build-vendor.sh",
    "build:identity": "bash scripts/build-identity.sh",
    "build:fellowship": "bash scripts/build-fellowship.sh",
    "build:bundles": "bash scripts/build-identity.sh && bash scripts/build-fellowship.sh",
    "sync:web": "bash scripts/sync-web.sh",
    "catalog:ebible": "python3 scripts/build-ebible-catalog.py",
    "catalog:videos": "python3 scripts/build-trinity-videos.py",
    "smoke": "bash scripts/smoke.sh"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "private": "true",
  "dependencies": {
    "@aparajita/capacitor-secure-storage": "^5.2.0",
    "@capacitor/android": "^6.2.1",
    "@capacitor/app": "^6.0.3",
    "@capacitor/cli": "^6.2.1",
    "@capacitor/core": "^6.2.1",
    "@capacitor/filesystem": "^6.0.4",
    "@capacitor/ios": "^6.2.1",
    "@capacitor/local-notifications": "^6.1.3",
    "@capacitor/share": "^6.0.4",
    "@cashu/cashu-ts": "^4.5.1",
    "@scure/bip39": "^2.2.0",
    "nostr-tools": "^2.23.5",
    "qrcode-generator": "^1.5.2",
    "web-push": "^3.6.7",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "esbuild": "^0.28.0"
  }
}
